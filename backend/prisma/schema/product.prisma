model Product {
  id          String   @id @default(uuid())

  sku         String   @unique
  name        String
  description String?

  unitPrice   Decimal  @db.Decimal(10,2)

  quantity    Int      @default(0)

  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}